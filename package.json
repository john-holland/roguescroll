{
  "name": "roguescroll-server",
  "version": "1.0.0",
  "description": "RogueScroll Game Server",
  "license": "MIT",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:watch": "webpack --mode development --watch",
    "build:docker": "docker build -t roguescroll .",
    "build:docker:dev": "docker build -t roguescroll:dev --build-arg NODE_ENV=development .",
    "clean": "rimraf dist",
    "clean:docker": "docker rmi roguescroll roguescroll:dev || true",
    "clean:all": "npm run clean && npm run clean:docker",
    "start:docker:dev": "docker-compose up --build"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cheerio": "^1.0.0",
    "compression": "^1.8.0",
    "express": "^4.18.2",
    "jquery": "^3.7.1",
    "jquery.transit": "^0.9.12",
    "mori": "^0.3.2",
    "uuid": "^9.0.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.27.2",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "handlebars": "^4.7.8",
    "handlebars-loader": "^1.7.3",
    "nodemon": "^2.0.22",
    "rimraf": "^5.0.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-subresource-integrity": "^5.2.0-rc.1"
  },
  "credits": {
    "cursor-ai": "@https://www.cursor.com/"
  }
}
